<Window x:Class="Pomodoro.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowActivated="False"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual"
        FontFamily="Segoe UI">

    <Border Background="#F01E1E22" CornerRadius="12" Padding="16,12" MaxWidth="280">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="16" ShadowDepth="3" Opacity="0.45"/>
        </Border.Effect>
        <StackPanel>
            <TextBlock Text="Pomodoro" Foreground="#888888" FontSize="10"
                       FontWeight="SemiBold" Margin="0,0,0,3"/>
            <TextBlock x:Name="MessageText" Foreground="White" FontSize="14"
                       TextWrapping="Wrap"/>
        </StackPanel>
    </Border>
</Window>
